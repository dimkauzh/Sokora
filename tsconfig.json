{
  "include": ["**/*", "package.json"],
  "compilerOptions": {
    "target": "esnext",
    "lib": ["ESNext"],
    "module": "Preserve",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    // "outDir": "./dist", // For some reason this invalidates package.json in path
    "resolveJsonModule": true,
    "composite": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "types": ["bun-types"],
    "paths": {
      "database/*": ["./src/utils/database/*"],
      "embeds/*": ["./src/utils/embeds/*"],
      "events/*": ["./src/events/*"],
      "handlers/*": ["./src/handlers/*"],
      "utils/*": ["./src/utils/*"],
      "src/*": ["./src/*"],
      "package": ["./package.json"]
    }
  }
}
