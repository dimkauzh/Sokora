    "chart.js": "^4.5.1",
    "chartjs-node-canvas": "^5.0.0",
    "colorthief": "^3.3.1",
    "discord.js": "^14.26.3",
    "enhanced-ms": "^4.3.0",
    "mathjs": "^15.2.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "bun-types": "^1.3.13",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  }
