{
  "name": "sokora",
  "description": "Welcome to Sokora, a multipurpose Discord bot that lets you manage your servers easily.",
  "contributors": [
    "The Sokora team",
    "The GitHub contributors"
  ],
  "version": "0.4",
  "main": "./src/index.ts",
  "type": "module",
  "scripts": {
    "setup": "bun i && bun run cli/setup.ts",
    "buildProj": "bun tsgo -p tsconfig.json",
    "altdev": "bun --watch ./dist/src/bot.js",
    "dev": "bun --watch ./src/bot.ts",
    "start": "bun ./src/index.ts",
    "ql": "prettier --w .; eslint . --fix"
  },
  "dependencies": {
    "@hokkiai/djs-level-importer": "^1.2.0",
    "@top-gg/sdk": "^3.1.6",
    "chart.js": "^4.5.1",
    "chartjs-node-canvas": "^5.0.0",
    "colorthief": "^3.3.1",
    "discord.js": "^14.26.4",
    "enhanced-ms": "^4.3.0",
    "mathjs": "^15.2.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@typescript/native-preview": "^7.0.0-dev.20260517.1",
    "bun-types": "^1.3.14",
    "eslint": "^10.4.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  }
}
