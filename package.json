    "discord.js": "^14.25.1",
    "enhanced-ms": "^4.2.0",
    "ky": "^1.14.1",
    "mathjs": "^15.1.0",
    "node-vibrant": "^4.0.3",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "bun-types": "^1.3.5",
    "eslint": "^9.39.2",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1"
