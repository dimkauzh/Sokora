    "ms": "^2.1.3",
    "node-vibrant": "^3.2.1-alpha.1",
    "sharp": "^0.33.5",
    "topgg-autoposter": "^2.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/figlet": "^1.7.0",
    "@types/ms": "^0.7.34",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "bun-types": "^1.2.15",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1"
