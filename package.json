{
  "name": "sokora",
  "description": "Welcome to Sokora, a multipurpose Discord bot that lets you manage your servers easily.",
  "contributors": [
    "The Sokora team",
    "The GitHub contributors"
  ],
  "version": "0.3",
  "main": "./src/index.ts",
  "type": "module",
  "scripts": {
    "setup": "bun i && bun run cli/setup.ts",
    "dev": "bun --watch ./src/bot.ts",
    "start": "bun ./src/index.ts",
    "prettier": "prettier --w .",
    "lint": "eslint --cache ."
  },
  "dependencies": {
    "@top-gg/sdk": "^3.1.6",
    "chart.js": "^4.5.0",
    "chartjs-node-canvas": "^5.0.0",
    "discord.js": "^14.21.0",
    "mathjs": "^14.6.0",
    "ms": "^2.1.3",
    "node-vibrant": "^4.0.3",
    "sharp": "^0.34.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/ms": "^2.1.0",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "bun-types": "^1.2.20",
    "eslint": "^9.33.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.40.0"
  }
}
